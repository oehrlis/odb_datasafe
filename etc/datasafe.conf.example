# =============================================================================
# Data Safe Configuration File (v0.7.0)
# =============================================================================
# This is the generic configuration file loaded by all Data Safe scripts.
# Script-specific configs can be created as: etc/<script_name>.conf
#
# Configuration Precedence (later overrides earlier):
#   1. Script defaults (in code)
#   2. .env file (project root)
#   3. This file (etc/datasafe.conf)
#   4. Script-specific config (etc/<script>.conf)
#   5. Command-line arguments
# =============================================================================

# -----------------------------------------------------------------------------
# OCI Configuration
# -----------------------------------------------------------------------------

# OCI CLI configuration
#OCI_CLI_PROFILE="DEFAULT"
#OCI_CLI_REGION="eu-frankfurt-1"
#OCI_CLI_CONFIG_FILE="${HOME}/.oci/config"

# -----------------------------------------------------------------------------
# Data Safe Common Settings
# -----------------------------------------------------------------------------

# Default root compartment for Data Safe targets
# Override with -c/--compartment or DS_ROOT_COMP_OCID env var
#COMPARTMENT="ocid1.compartment.oc1..aaaa..."
#DS_ROOT_COMP_OCID="ocid1.compartment.oc1..aaaa..."

# Default compartment for on-premises connectors
# If not set, uses DS_ROOT_COMP. Override with --connector-compartment
#DS_CONNECTOR_COMP="ocid1.compartment.oc1..aaaa..."
#DS_CONNECTOR_COMP_OCID="ocid1.compartment.oc1..aaaa..."

# Default lifecycle states to filter
#LIFECYCLE_STATE="NEEDS_ATTENTION"

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------

# Database domain for service names
#DB_DOMAIN="oradba.ch"

# Default listener port
#LISTENER_PORT="1521"

# Service name template for ds_target_update_service.sh (non-root/PDB targets).
# Brace-style placeholders derived from the target display name:
#   {pdb}/{PDB}       PDB name lower/uppercase
#   {cdb}/{CDB}       CDB name lower/uppercase
#   {cluster}/{CLUSTER} Cluster name lower/uppercase
#   {sid}/{SID}       Oracle SID lower/uppercase (alias for cdb)
#   {domain}          DB_DOMAIN value
#SERVICE_TEMPLATE="{pdb}_exa.{domain}"

# Service name template for CDB$ROOT targets in ds_target_update_service.sh.
# When unset, root targets are skipped with a warning.
#ROOT_SERVICE_TEMPLATE="{cdb}.{domain}"

# Default service protocol
#SERVICE_PROTOCOL="TCP"

# Data Safe admin user settings
#DATASAFE_USER="DS_ADMIN"
#COMMON_USER_PREFIX="C##"

# Target name parsing for ds_target_list.sh --overview and
# root target detection in ds_target_update_credentials.sh
# Default pattern is: <cluster>_<oracle_sid>_<cdb/pdb>
#DS_TARGET_NAME_SEPARATOR="_"
#DS_TARGET_NAME_CDBROOT_REGEX="^(CDB\\$ROOT|CDBROOT)$"
#DS_TARGET_NAME_ROOT_LABEL="CDB$ROOT"
# Optional SID token matcher for default split parser (helps when db names contain underscores)
#DS_TARGET_NAME_SID_REGEX="^cdb[0-9]+[[:alnum:]]*$"
# Optional regex override with 3 capture groups: cluster, sid, cdb/pdb
#DS_TARGET_NAME_REGEX="^(.+)_([^_]+)_(.+)$"

# -----------------------------------------------------------------------------
# On-Premises Connector
# -----------------------------------------------------------------------------

# Default on-premises connector (name or OCID)
#ONPREM_CONNECTOR="my-connector"
#ONPREM_CONNECTOR_OCID="ocid1.datasafeonpremconnector.oc1..aaaa..."

# Registration defaults for ds_target_register.sh
# Default target compartment when --compartment is not provided
#DS_REGISTER_COMPARTMENT="ocid1.compartment.oc1..aaaa..."
# Optional comma-separated connector pool for auto-selection when
# --connector and ONPREM_CONNECTOR* are not provided
#ONPREM_CONNECTOR_LIST="ds-conn-a,ds-conn-b,ocid1.datasafeonpremconnector.oc1..aaaa..."
# Alternative legacy-compatible variable name (same behavior)
#DS_ONPREM_CONNECTOR_LIST="ds-conn-a,ds-conn-b"

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------

# Log level: 0=TRACE, 1=DEBUG, 2=INFO, 3=WARN, 4=ERROR, 5=FATAL
#LOG_LEVEL=2

# Enable/disable colors: auto|always|never
#LOG_COLORS="auto"

# Log file (optional, per-script or global)
#LOG_FILE="/var/log/datasafe/datasafe.log"

# -----------------------------------------------------------------------------
# Behavior Settings
# -----------------------------------------------------------------------------

# Dry-run mode (override with --dry-run)
#DRY_RUN=false

# Normal lifecycle states for ds_target_list.sh --health-overview
#HEALTH_NORMAL_STATES="ACTIVE,UPDATING"

# Show stack traces on errors
#SHOW_STACKTRACE=true

# Enable cleanup on exit
#CLEANUP_ON_EXIT=true

# -----------------------------------------------------------------------------
# Tag Configuration  (used by ds_target_update_tags.sh)
# -----------------------------------------------------------------------------

# Tag namespace applied to all defined tags on Data Safe targets.
#TAG_NAMESPACE="DBSec"

# Tag key names within the namespace.
#ENVIRONMENT_TAG="Environment"
#CONTAINER_STAGE_TAG="ContainerStage"
#CONTAINER_TYPE_TAG="ContainerType"
#CLASSIFICATION_TAG="Classification"

# Regex for Environment tag derivation from compartment name.
# Capture group 1 is used as the Environment value.
# When unset, Environment defaults to "undef".
# Adapt the pattern to your compartment naming convention.
#
#   Pattern                            Compartment example              → Env
#   ---------------------------------- -------------------------------- ------
#   '^cmp-.*-([^-]+)-projects$'        cmp-org-unit-prod-projects       → prod
#   '^.*-(dev|test|qs|prod)$'          acme-prod                       → prod
#   '^[^-]+-([^-]+)-.*$'              acme-prod-unit-projects          → prod
#
#DS_ENV_COMP_REGEX='^cmp-.*-([^-]+)-projects$'

# Required tags (informational / used by ds_find_untagged_targets.sh)
#REQUIRED_TAGS="Classification,Environment,Owner"

# -----------------------------------------------------------------------------
# Performance & Limits
# -----------------------------------------------------------------------------

# Maximum concurrent operations (for future parallel processing)
#MAX_CONCURRENT=5

# OCI CLI timeout (seconds)
#OCI_TIMEOUT=300

# Wait for state timeout (seconds)
#WAIT_TIMEOUT=600

# Target list cache TTL (seconds). Set 0 to disable caching.
#DS_TARGET_CACHE_TTL=300

# =============================================================================
# End of Configuration
# =============================================================================
